PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_NAME=sparklights_db
DB_USER=postgres
DB_PASSWORD=your password

JWT_SECRET=your_secret_key

NODE_ENV=development

# Vercel — set DATABASE_URL + JWT secrets in the Vercel dashboard
# FRONTEND_URL=https://your-domain.vercel.app
PORT=3001
API_BASE_URL=http://localhost:3001/v1

# Local Postgres
# DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/flower_admin?schema=public"

# Supabase (Project Settings → Database → Connection string)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
VITE_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt
SUPABASE_ANON_KEY=your-anon-jwt

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=your-access-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-at-least-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# M-Pesa Daraja
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:3001/v1/payments/mpesa/callback
MPESA_ENV=sandbox

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Africa's Talking
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=LUXEFLOWERS

# WhatsApp Business
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_VERIFY_TOKEN=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=marykamaa548@gmail.com

# Store defaults
STORE_NAME="Spark Lights 254"
STORE_TIMEZONE=Africa/Nairobi
