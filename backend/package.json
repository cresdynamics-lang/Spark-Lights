    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "resend": "^3.2.0",
    "stripe": "^15.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
